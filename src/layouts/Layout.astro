---
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import Head from "../components/Head.astro";
import type { Ogp } from "../types/Ogp";
import { UIDOLA_THUMBNAIL } from "../util/const";

const { url } = Astro.props;

const ogp: Ogp = {
  title: "uidolaのプロフィール",
  description: "uidolaのプロフィール",
  thumbnail: UIDOLA_THUMBNAIL,
  url: url,
  pageType: "website",
};
---

<!doctype html>
<html lang="ja" class="overflow-x-hidden">
  <Head ogp={ogp} />
  <body class="bg-sub bg-fixed tracking-wider overflow-x-hidden">
    <slot />
    <Footer />
    <button
      id="back-to-top"
      class="fixed bottom-6 right-6 z-50 w-12 h-12 rounded-full bg-main text-sub shadow-lg cursor-pointer opacity-0 pointer-events-none transition-opacity duration-300 flex items-center justify-center hover:brightness-110"
      aria-label="トップへ戻る"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
      </svg>
    </button>
    <script>
      const btn = document.getElementById('back-to-top');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 300) {
          btn?.classList.remove('opacity-0', 'pointer-events-none');
          btn?.classList.add('opacity-100');
        } else {
          btn?.classList.add('opacity-0', 'pointer-events-none');
          btn?.classList.remove('opacity-100');
        }
      });
      btn?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    </script>
  </body>
</html>
